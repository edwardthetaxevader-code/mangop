{
	"name": "@mercuryworkshop/scramjet",
	"version": "2.0.0-alpha",
	"description": "An experimental web proxy that aims to be the successor to Ultraviolet",
	"type": "module",
	"types": "./dist/types/index.d.ts",
	"repository": {
		"type": "git",
		"url": "https://github.com/MercuryWorkshop/scramjet"
	},
	"scripts": {
		"build": "rspack build --mode production",
		"build:types": "rslib build && rm -rf dist/temp",
		"build:all": "npm run build && npm run build:types",
		"dev": "node server.js",
		"dev:debug": "DEBUG=1 node server.js",
		"format": "prettier --write .",
		"lint": "eslint ./src/",
		"lint:fix": "eslint ./src/ --fix",
		"docs": "typedoc"
	},
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"default": "./lib/noop.js"
		},
		"./path": {
			"types": "./lib/index.d.ts",
			"default": "./lib/index.cjs"
		},
		"./bundled": {
			"types": "./dist/types/index.d.ts",
			"default": "./dist/scramjet.bundle.js"
		}
	},
	"files": [
		"dist",
		"lib"
	],
	"keywords": [],
	"author": "",
	"license": "MIT",
	"pnpm": {
		"onlyBuiltDependencies": ["core-js"],
		"ignoredBuiltDependencies": []
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.1",
		"@eslint/js": "^9.35.0",
		"@fastify/static": "^8.2.0",
		"@mercuryworkshop/bare-as-module3": "^2.2.5",
		"@mercuryworkshop/epoxy-transport": "^2.1.28",
		"@mercuryworkshop/libcurl-transport": "^1.5.0",
		"@mercuryworkshop/wisp-js": "^0.3.3",
		"@nebula-services/bare-server-node": "^2.0.4",
		"@rsdoctor/rspack-plugin": "^1.2.3",
		"@rslib/core": "^0.13.2",
		"@rspack/cli": "^1.5.3",
		"@rspack/core": "^1.5.3",
		"@types/eslint": "^9.6.1",
		"@types/estree": "^1.0.8",
		"@types/node": "^24.3.1",
		"@types/serviceworker": "^0.0.152",
		"@typescript-eslint/eslint-plugin": "^8.43.0",
		"@typescript-eslint/parser": "^8.43.0",
		"dotenv": "^17.2.2",
		"eslint": "^9.35.0",
		"fastify": "^5.6.0",
		"glob": "^11.0.3",
		"prettier": "^3.6.2",
		"ts-checker-rspack-plugin": "^1.1.5",
		"tsc-alias": "^1.8.16",
		"tslib": "^2.8.1",
		"typescript": "^5.9.2"
	},
	"dependencies": {
		"@mercuryworkshop/bare-mux": "^2.1.7",
		"dom-serializer": "^2.0.0",
		"domhandler": "^5.0.3",
		"domutils": "^3.2.2",
		"htmlparser2": "10.0.0",
		"idb": "^8.0.3",
		"parse-domain": "^8.2.2",
		"set-cookie-parser": "^2.7.1"
	}
}
